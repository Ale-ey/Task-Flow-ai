rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---

    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // --- User Schema ---
    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'email', 'displayName', 'photoURL', 'lastLogin']) &&
             data.keys().hasAll(['uid', 'email']) &&
             data.uid == request.auth.uid &&
             data.email is string && data.email.size() <= 256 &&
             data.displayName is string && data.displayName.size() <= 128 &&
             data.photoURL is string && (data.photoURL == null || data.photoURL.size() <= 1024) &&
             data.lastLogin == request.time;
    }

    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && 
                      incoming().uid == existing().uid &&
                      isValidUser(incoming());
    }

    // --- Todo Schema ---
    function isValidTodo(data) {
      return data.keys().hasAll(['id', 'text', 'completed', 'category', 'userId', 'createdAt']) &&
             data.keys().size() == 6 &&
             data.id is string && data.id.size() <= 128 &&
             data.text is string && data.text.size() <= 1000 &&
             data.completed is bool &&
             data.category in ['personal', 'work', 'shopping', 'health', 'urgent'] &&
             data.userId == request.auth.uid &&
             data.createdAt == request.time;
    }

    match /users/{userId}/todos/{todoId} {
      allow list: if isOwner(userId);
      allow get: if isOwner(userId);
      
      allow create: if isOwner(userId) && 
                       isValidId(todoId) && 
                       isValidTodo(incoming());
      
      allow update: if isOwner(userId) &&
                       isValidTodo(incoming()) &&
                       (
                         // Action: Toggle completion
                         (incoming().diff(existing()).affectedKeys().hasOnly(['completed'])) ||
                         // Action: Edit text/category
                         (incoming().diff(existing()).affectedKeys().hasOnly(['text', 'category']))
                       ) &&
                       incoming().id == existing().id &&
                       incoming().createdAt == existing().createdAt &&
                       incoming().userId == existing().userId;
      
      allow delete: if isOwner(userId);
    }
  }
}
